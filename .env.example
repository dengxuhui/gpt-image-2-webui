# 上游 OpenAI 兼容 API 的密钥（服务端代理与 MCP server 共用的兜底 key）
OPENAI_API_KEY=sk-xxxx

# 可选：自定义上游 base URL（裸域名 / .../v1 均可，留空则用官方 https://api.openai.com/v1）
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# 可选：MCP 生成图片的落盘目录，默认项目根的 ./generated
# IMGX_OUTPUT_DIR=./generated

# 可选：子路径 / CDN 部署的静态资源前缀
# NEXT_ASSET_PREFIX=
